VEKTOR_API_URL=http://127.0.0.1:4321
VEKTOR_COLLABORATION_HOST=127.0.0.1:8080
VEKTOR_SITE_URL=http://127.0.0.1:4321

VEKTOR_OTEL_ENABLED=1
VEKTOR_OTEL_SERVICE_NAME=
VEKTOR_OTEL_EXPORTER_OTLP_ENDPOINT=
