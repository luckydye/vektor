# VEKTOR_IN_MEMORY_DB=1

AUTH_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
OAUTH_AUTHORIZATION_URL="https://example.com/oauth/authorize"
OAUTH_CLIENT_ID="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
OAUTH_CLIENT_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
OAUTH_PROVIDER_ID="sso"
OAUTH_SCOPES="email,profile,openid"
OAUTH_TOKEN_URL="https://example.com/oauth/token"
OAUTH_USERINFO_URL="https://example.com/oauth/userinfo"

OPENROUTER_API_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
OPENROUTER_MODEL="qwen/qwen3.5-397b-a17b"
# Provider priority: Ollama, then Anthropic, then OpenRouter
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-6"
OLLAMA_BASE_URL="http://127.0.0.1:11434"
OLLAMA_MODEL="qwen3:latest"
VEKTOR_ACP_COMMAND="opencode acp"
VEKTOR_SEARCH_EMBEDDINGS_PROVIDER="local"
VEKTOR_SEARCH_EMBEDDINGS_MODEL="text-embedding-3-small"
VEKTOR_SEARCH_EMBEDDINGS_BASE_URL="https://openrouter.ai/api/v1"
