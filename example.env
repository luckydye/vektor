VEKTOR_API_URL=http://127.0.0.1:4321
VEKTOR_COLLABORATION_HOST=127.0.0.1:8080
VEKTOR_SITE_URL=http://127.0.0.1:4321

# Document publication and comment email notifications. Delivery remains
# disabled in production until both VEKTOR_EMAIL_FROM and VEKTOR_SMTP_HOST are set.
VEKTOR_EMAIL_FROM="Vektor <notifications@example.com>"
VEKTOR_SMTP_HOST="smtp.example.com"
VEKTOR_SMTP_PORT="587"
VEKTOR_SMTP_SECURE="0"
VEKTOR_SMTP_USER=""
VEKTOR_SMTP_PASSWORD=""

# Set to "1" together with VEKTOR_NO_AUTH=1 for a fully ephemeral test server
# VEKTOR_IN_MEMORY_DB=1

AUTH_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
OAUTH_AUTHORIZATION_URL="https://example.com/oauth/authorize"
OAUTH_CLIENT_ID="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
OAUTH_CLIENT_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
OAUTH_PROVIDER_ID="sso"
OAUTH_SCOPES="email,profile,openid"
OAUTH_TOKEN_URL="https://example.com/oauth/token"
OAUTH_USERINFO_URL="https://example.com/oauth/userinfo"

# Google login. Set both to enable a "Continue with Google" button on the login
# screen. Create OAuth credentials at https://console.cloud.google.com/apis/credentials
# and add "<SITE_URL>/api/auth/callback/google" as an authorized redirect URI.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Optional: override the redirect URI (defaults to <SITE_URL>/api/auth/callback/google)
# GOOGLE_REDIRECT_URI=""

OPENROUTER_API_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
OPENROUTER_MODEL="qwen/qwen3.5-397b-a17b"
# Provider priority: Ollama, then Anthropic, then OpenRouter
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-6"
OLLAMA_BASE_URL="http://127.0.0.1:11434"
OLLAMA_MODEL="qwen3:latest"

# CLI Env
VEKTOR_URL=http://127.0.0.1:4321/
VEKTOR_SPACE_ID="xxx"
VEKTOR_TOKEN="xxx"
