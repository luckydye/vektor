---
import "../styles/index.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Vector Tile Test</title>
    <style>
      html, body { margin: 0; height: 100%; overflow: hidden; background: #1a1a1a; }
      canvas { display: block; }
      #info {
        position: fixed;
        top: 12px;
        left: 12px;
        background: rgba(0,0,0,0.65);
        color: #ddd;
        font: 12px/1.6 monospace;
        padding: 8px 12px;
        border-radius: 6px;
        pointer-events: none;
        white-space: pre;
      }
    </style>
  </head>
  <body>
    <canvas id="map"></canvas>
    <div id="info">loading…</div>

    <script>
      import {
        buildTransform,
        createVectorTileMap,
        createViewportControls,
        type VectorTileStyleFn,
      } from "../viewport/index.ts";

      const WORLD_SIZE = 512;

      const canvas = document.getElementById("map") as HTMLCanvasElement;
      const ctx = canvas.getContext("2d")!;
      const info = document.getElementById("info")!;

      let dpr = devicePixelRatio;
      // World center of tile z=6 x=32 y=21 (Western Europe / London area).
      // tileZ = minZ(0) + floor(log2(zoom)) → zoom=64 → tileZ=6, same detail as before.
      let camera = { centerX: 260, centerY: 172, zoom: 64 };
      let rafPending = false;
      let debugOverlay = false;

      function scheduleDraw() {
        if (!rafPending) {
          rafPending = true;
          requestAnimationFrame(() => { rafPending = false; draw(); });
        }
      }

      function screenSize() {
        return { width: canvas.width / dpr, height: canvas.height / dpr };
      }

      function fitRef() {
        return { x: 0, y: 0, width: WORLD_SIZE, height: WORLD_SIZE };
      }

      // Dark style covering both Mapbox Streets v8 and OpenMapTiles layer names.
      const style: VectorTileStyleFn = (layerName, props) => {
        switch (layerName) {
          case "water":
          case "waterway":
            return { fill: "#1a3a5c", stroke: null };
          case "landuse":
          case "landcover":
            return props.class === "grass" || props.class === "park" || props.subclass === "park"
              ? { fill: "#1e3320", stroke: null }
              : { fill: "#222", stroke: null };
          // Mapbox Streets v8: "road" / OpenMapTiles: "transportation"
          case "road":
          case "transportation":
            switch (props.class) {
              case "motorway":  return { fill: null, stroke: "#c8881a", strokeWidth: 2 };
              case "trunk":
              case "primary":   return { fill: null, stroke: "#888", strokeWidth: 1.5 };
              case "secondary":
              case "tertiary":  return { fill: null, stroke: "#555", strokeWidth: 1 };
              default:          return { fill: null, stroke: "#3a3a3a", strokeWidth: 0.5 };
            }
          case "building":
            return { fill: "#2e2e2e", stroke: "#3a3a3a", strokeWidth: 0.5 };
          // Mapbox Streets v8: "admin" / OpenMapTiles: "boundary"
          case "admin":
          case "boundary":
            return (props.admin_level === 2 || props.admin_level === "2")
              ? { fill: null, stroke: "#5a7a9a", strokeWidth: 1 }
              : null;
          default:
            return null;
        }
      };

      const MAPBOX_TOKEN = import.meta.env.VEKTOR_MAPBOX_TOKEN;

      const tileMap = createVectorTileMap({
        getTileUrl: (z, x, y) =>
          `https://api.mapbox.com/v4/mapbox.mapbox-streets-v8/${z}/${x}/${y}.mvt?access_token=${MAPBOX_TOKEN}`,
        worldWidth: WORLD_SIZE, worldHeight: WORLD_SIZE,
        minZ: 0, maxZ: 14,
        devicePixelRatio: devicePixelRatio,
        style,
        onLoad: scheduleDraw,
      });

      function draw() {
        const screen = screenSize();
        const t = buildTransform(camera, screen, fitRef());

        ctx.clearRect(0, 0, canvas.width, canvas.height);
        ctx.fillStyle = "#1a2a3a";
        ctx.fillRect(0, 0, canvas.width, canvas.height);

        ctx.save();
        ctx.scale(dpr, dpr);
        const { tileZ, loaded, total } = tileMap.draw(ctx, t, camera.zoom);
        if (debugOverlay) tileMap.drawDebug(ctx, t, camera.zoom);
        ctx.restore();

        info.textContent = [
          `tile zoom  ${tileZ}`,
          `tiles      ${loaded}/${total} loaded`,
          `camera zoom  ${camera.zoom.toFixed(2)}`,
          debugOverlay ? "debug  ON  (D to toggle)" : "D — debug overlay",
        ].join("\n");
      }

      function resize() {
        dpr = devicePixelRatio;
        canvas.width = innerWidth * dpr;
        canvas.height = innerHeight * dpr;
        canvas.style.width = innerWidth + "px";
        canvas.style.height = innerHeight + "px";
        draw();
      }

      createViewportControls({
        target: canvas,
        getCamera: () => camera,
        setCamera: (c) => {
          camera = c;
          const t = buildTransform(camera, screenSize(), fitRef());
          const { width, height } = screenSize();
          tileMap.ensureTiles(camera.zoom, t, width, height);
          scheduleDraw();
        },
        getScreen: screenSize,
        getFit: fitRef,
        maxZoom: 16384,
      });

      window.addEventListener("keydown", (e) => {
        if (e.key === "d" || e.key === "D") { debugOverlay = !debugOverlay; scheduleDraw(); }
      });
      window.addEventListener("resize", resize);
      resize();
      tileMap.ensureTiles(camera.zoom, buildTransform(camera, screenSize(), fitRef()), innerWidth, innerHeight);
    </script>
  </body>
</html>
