---
import Login from "#components/Login.vue";
import LandingLayout from "#layouts/LandingLayout.astro";
---

<LandingLayout title="Vektor">
  <div class="min-h-screen flex">

    <!-- Left: branded marketing panel -->
    <aside
      class="hidden lg:flex w-[54%] xl:w-[52%] flex-col justify-between p-12 relative overflow-hidden"
      style="background: linear-gradient(150deg, #2a1035 0%, #0e0415 100%)"
    >
      <!-- ambient glows -->
      <div class="absolute inset-0 pointer-events-none overflow-hidden">
        <div
          class="absolute -top-40 -right-40 w-[560px] h-[560px] rounded-full"
          style="background: radial-gradient(circle, rgba(162,94,187,0.22) 0%, transparent 68%)"
        ></div>
        <div
          class="absolute -bottom-32 -left-32 w-[420px] h-[420px] rounded-full"
          style="background: radial-gradient(circle, rgba(120,55,143,0.18) 0%, transparent 70%)"
        ></div>
      </div>

      <!-- Logo -->
      <div class="relative z-10 flex items-center gap-2.5">
        <div
          class="rounded-lg flex items-center justify-center p-1.5"
          style="background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.12)"
        >
            <img src="/favicon_light.png" alt="" width="28px" />
        </div>
        <span
          class="text-white font-semibold"
          style="font-size: 15px; letter-spacing: -0.01em">Vektor</span
        >
      </div>

      <!-- Hero copy + feature list -->
      <div class="relative z-10">
        <h1
          class="font-bold text-white mb-4"
          style="font-size: 2.3rem; line-height: 1.18; letter-spacing: -0.03em"
        >
          Your team's knowledge,<br />organized.
        </h1>
        <p
          class="mb-10 leading-relaxed"
          style="font-size: 14px; color: #c2b6d4; line-height: 1.75"
        >
            A self-hosted documentation platform with real-time collaboration,<br/>
            rich editing, and zero external dependencies.
        </p>

        <ul class="space-y-3">
          {
            [
              {
                label: "Real-time collaboration across your whole team",
                d: "M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2M23 21v-2a4 4 0 0 0-3-3.87M9 7a4 4 0 1 0 0-8 4 4 0 0 0 0 8zM16 3.13a4 4 0 0 1 0 7.75",
              },
              {
                label: "Multiple spaces to organize teams and projects",
                d: "M3 7v10a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-6l-2-2H5a2 2 0 0 0-2 2z",
              },
              {
                label: "Rich editor with embeds, tables, and extensions",
                d: "M12 20h9M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z",
              },
              {
                label: "Self-hosted, ships as a single binary",
                d: "M22 12h-4l-3 9L9 3l-3 9H2",
              },
            ].map((f) => (
              <li class="flex items-center gap-3">
                <div
                  class="w-8 h-8 rounded-lg flex-none flex items-center justify-center"
                  style="background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.08)"
                >
                  <svg
                    aria-hidden="true"
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="rgba(194,182,212,0.85)"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d={f.d} />
                  </svg>
                </div>
                <span style="font-size: 13px; color: #c2b6d4">{f.label}</span>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Footer -->
      <div class="relative z-10">
        <p style="font-size: 11.5px; color: #56295f; letter-spacing: 0.02em">
          Open source · Self-hosted · Privacy-first
        </p>
      </div>
    </aside>

    <!-- Right: login panel -->
    <div
      class="flex-1 flex flex-col justify-center items-center px-8 py-16"
    >
      <div class="w-full max-w-[360px]">

        <!-- Mobile-only logo -->
        <div class="flex items-center gap-2.5 mb-10 lg:hidden">
          <div class="w-7 h-7 rounded-lg flex items-center justify-center bg-primary-500">
            <svg aria-hidden="true" width="13" height="13" viewBox="0 0 16 16" fill="none">
              <path
                d="M2 2.5L8 13.5L14 2.5"
                stroke="white"
                stroke-width="2.25"
                stroke-linecap="round"
                stroke-linejoin="round"
              ></path>
            </svg>
          </div>
          <span class="font-semibold text-neutral-900" style="font-size: 15px">Vektor</span>
        </div>

        <Login client:load />
      </div>
    </div>
  </div>
</LandingLayout>
