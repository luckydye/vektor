---
import SpaceApp from "#components/SpaceApp.vue";
import { verifyDocumentRole, verifySpaceRole } from "#db/api.ts";
import { getDocument, getDocumentBySlug } from "#db/documents.ts";
import { getHeaderImageAspectRatio } from "#files/headerImageAspect.ts";
import BaseLayout from "#layouts/BaseLayout.astro";
import { parseSidebarWidth, SIDEBAR_WIDTH_KEY } from "#utils/sidebarState.ts";
import {
  requireSpaceViewer,
  resolveSpacePage,
  resolveUserSpaceRole,
} from "#utils/spacePage.ts";

const result = await resolveSpacePage(Astro);
if (result.response) return result.response;
const { space } = result;

const docSlugMatch = Astro.url.pathname.match(/\/doc\/(.+)$/);
const settingsPath =
  Astro.url.pathname === `/${space.slug}/settings` ||
  Astro.url.pathname.startsWith(`/${space.slug}/settings/`);

if (settingsPath) {
  if (!Astro.locals.session) {
    return new Response(null, {
      status: 302,
      headers: { Location: "/login" },
    });
  }

  try {
    await verifySpaceRole(space.id, Astro.locals.user?.id ?? "", "owner");
  } catch (error) {
    if (error instanceof Response) return error;
    throw error;
  }
}

const documentRecord = docSlugMatch
  ? await getDocumentBySlug(space.id, docSlugMatch[1])
  : null;

if (docSlugMatch && !documentRecord) {
  // A document addressed by its ID redirects to its canonical slug URL, matching
  // the dedicated doc page this catch-all replaced. Prevents ID-guessing from
  // rendering the shell for a document whose slug the URL never resolved.
  const documentById = await getDocument(space.id, docSlugMatch[1]);
  if (documentById) {
    return Astro.redirect(`/${space.slug}/doc/${documentById.slug}${Astro.url.search}`);
  }
}

let initialDocument = documentRecord
  ? JSON.parse(JSON.stringify(documentRecord))
  : undefined;

let hasDirectDocumentAccess = false;
if (initialDocument) {
  try {
    await verifyDocumentRole(
      space.id,
      initialDocument.id,
      Astro.locals.user?.id ?? null,
      "viewer",
    );
    hasDirectDocumentAccess = true;
  } catch (error) {
    if (!Astro.locals.session && error instanceof Response) {
      return new Response(null, {
        status: 302,
        headers: { Location: "/login" },
      });
    }
  }
}

if (!hasDirectDocumentAccess) {
  const accessDenied = await requireSpaceViewer(Astro, space);
  if (accessDenied) return accessDenied;
}

if (initialDocument) {
  initialDocument.headerImageAspectRatio = await getHeaderImageAspectRatio(
    space.id,
    initialDocument.properties.headerImage,
  );
}

if (Astro.locals.session) {
  Astro.cookies.set("lastVisitedSpace", space.slug, {
    path: "/",
    maxAge: 60 * 60 * 24 * 90, // 90 days
    sameSite: "lax",
    httpOnly: true,
  });
}

const userRole = await resolveUserSpaceRole(Astro, space);
// Serialize Date fields to ISO strings so the server-rendered HTML matches the
// client props (Astro serializes props via JSON.stringify, which converts Date
// objects to strings). Without this, data-updated-at / data-created-at
// attributes differ between server and client, triggering hydration mismatches.
const initialSpace = JSON.parse(
  JSON.stringify({ ...space, userRole: userRole ?? undefined }),
);

const initialSidebarWidth = parseSidebarWidth(
  Astro.cookies.get(SIDEBAR_WIDTH_KEY)?.value,
);
---

<BaseLayout
  title={space.name}
  brandColor={space.preferences?.brandColor}
  spaceId={space.id}
>
  <SpaceApp
    client:load
    url={Astro.url.pathname}
    initialSpace={initialSpace}
    initialDocument={initialDocument}
    initialSidebarWidth={initialSidebarWidth}
    replicaScope={Astro.locals.user?.id ? `user:${Astro.locals.user.id}` : "public"}
  />
</BaseLayout>
