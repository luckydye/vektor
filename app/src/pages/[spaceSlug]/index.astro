---
import AIChatPanel from "~/src/components/AIChatPanel.vue";
import PinnedDocument from "~/src/components/PinnedDocument.vue";
import RecentDocuments from "~/src/components/RecentDocuments.vue";
import ExtensionView from "../../components/ExtensionView.vue";
import SpaceActivity from "../../components/SpaceActivity.vue";
import { getDocument } from "../../db/documents.ts";
import { listExtensions } from "../../db/extensions.ts";
import SpaceLayout from "../../layouts/SpaceLayout.astro";
import { requireSpaceViewer, resolveSpacePage } from "../../utils/spacePage.ts";

const result = await resolveSpacePage(Astro);
if (result.response) {
  return result.response;
}
const { space } = result;

// Check ACL permissions - user must be a member of the space
const accessDenied = await requireSpaceViewer(Astro, space);
if (accessDenied) {
  return accessDenied;
}

const document = await getDocument(space.id, space.id);

// Get extension views for home page placements
const extensions = await listExtensions(space.id);
const homeTopViews = extensions.flatMap((ext) =>
  (ext.manifest.routes || [])
    .filter((route) => route.placements?.includes("home-top"))
    .map((route) => ({ extensionId: ext.id, route })),
);
---

<SpaceLayout title={`${space.name} - Wiki`}>
	<div data-inset class="space-y-12 pt-m pb-20 lg:pb-8 h-full print:px-0 px-xs lg:px-xl md:ml-(--inset-left) md:mr-(--inset-right)">

  		{space.preferences.pinnedDocumentId && (
 			<PinnedDocument
				client:only
				spaceId={space.id}
				spaceSlug={space.slug}
				pinnedDocumentId={space.preferences.pinnedDocumentId}
 			/>
  		)}

		<div>
		    <RecentDocuments client:load spaceId={space.id} spaceSlug={space.slug} limit={10} />
		</div>

		{homeTopViews.length > 0 && (
			<div class="space-y-4 mb-20">
				{homeTopViews.map(({ extensionId, route }) => (
					<div>
						{(route.title || route.description) && (
							<div class="mb-3">
								{route.title && <h3 class="text-size-title">{route.title}</h3>}
								{route.description && <p class="text-size-medium text-neutral-600 mt-1">{route.description}</p>}
							</div>
						)}
						<ExtensionView client:only extensionId={extensionId} routePath={route.path} spaceId={space.id} />
					</div>
				))}
			</div>
		)}

		<div class="grid grid-cols-1 lg:grid-cols-2 gap-3xl mb-20">
			<SpaceActivity client:load spaceId={space.id} limit={15} />
		</div>
	</div>
	
	<AIChatPanel client:only slot="outer" />
</SpaceLayout>
