---
import { twMerge } from "tailwind-merge";
import DocumentActions from "~/src/components/DocumentActions.vue";
import DocumentProperties from "~/src/components/DocumentProperties.vue";
import NewDocumentPicker from "~/src/components/NewDocumentPicker.vue";
import TitleEditor from "~/src/components/TitleEditor.vue";
import DocumentContent from "../../components/DocumentContent.vue";
import SpaceLayout from "../../layouts/SpaceLayout.astro";
import { requireSpaceViewer, resolveSpacePage } from "../../utils/spacePage.ts";

const result = await resolveSpacePage(Astro);
if (result.response) {
  return result.response;
}
const { space } = result;

// Check ACL permissions - user must be a member of the space
const accessDenied = await requireSpaceViewer(Astro, space);
if (accessDenied) {
  return accessDenied;
}

const typeParam = Astro.url.searchParams.get("type");
const type = typeParam || "document";
const showPicker = !typeParam;
const category = Astro.url.searchParams.get("category") || undefined;
const title = type === "canvas" ? "Untitled Canvas" : "Untitled Document";
const spaceSlug = Astro.params.spaceSlug as string;

const isCanvas = type === "canvas";
const isApp = type === "app";
const isCsv = type === "csv";
const isWorkflow = type === "workflow";
const isPaddedDocument = !isCanvas && !isApp && !isCsv && !isWorkflow;
---

<SpaceLayout title={`${title} - ${space.name} - Wiki`}>
  <!-- Inset content past the fixed sidebar — except canvas docs, which render
       full-bleed behind the nav and inset only their absolute header below. -->
  <div
    data-inset
    class={twMerge(
      "min-h-0 flex-1",
      !isCanvas && "md:mr-(--inset-right) md:ml-(--inset-left)",
    )}
  >
    <div
      class={twMerge(
        "relative mx-auto flex h-full w-full flex-col",
        isCsv ? "max-w-full" : "max-w-(--document-width)",
      )}
    >
      <!-- Document Header -->
      <div class={twMerge(
        isApp
          ? "hidden"
          : isCanvas
            ? "block pointer-events-none absolute top-xs right-0 left-0 z-20 lg:right-(--inset-right) lg:left-(--inset-left)"
            : "mb-xl pt-xs contents",
      )}>
        <div
          class="flex min-h-7 items-center justify-between px-xs lg:px-xl print:px-0 mt-2xs mb-4xs"
          data-inset
        >
          <div />
        </div>

        <div
          class={twMerge(
            "flex flex-row justify-between gap-6 py-3xs px-xs lg:gap-4 lg:px-xl print:px-0",
            isCanvas ? "pointer-events-auto" : "bg-neutral-10",
            "sticky top-0 z-10",
          )}
          data-inset
        >
          <div class="flex items-start justify-between w-full">
            <TitleEditor
              client:load
              initialEditMode={true}
              title={title}
            />
          </div>

          <DocumentActions
            client:only
            documentId={undefined}
            title={title}
            readonly={false}
          />
        </div>

        <div
          class={twMerge(
            "px-xs lg:px-xl print:px-0 mb-l",
            isCanvas && "pointer-events-auto",
          )}
          data-inset
        >
          <DocumentProperties
            client:only
            documentId={undefined}
            documentType={type}
            initialProperties={category ? { category } : {}}
          />
        </div>
      </div>

      <!-- Main Content -->
      <div
        class={twMerge(
          "max-w-none overflow-x-auto text-neutral-700 h-full",
          isPaddedDocument && "px-xs lg:px-xl print:px-0",
        )}
      >
        {showPicker && (
          <NewDocumentPicker client:load spaceSlug={spaceSlug} />
        )}

        <DocumentContent
          client:load
          spaceId={space.id}
          documentType={type}
          initialEditMode={true}
        />
      </div>
    </div>
  </div>
</SpaceLayout>
