---
import { twMerge } from "tailwind-merge";
import Canvas from "~/src/components/Canvas.vue";
import CommentManager from "~/src/components/CommentManager.vue";
import DocumentActions from "~/src/components/DocumentActions.vue";
import DocumentProperties from "~/src/components/DocumentProperties.vue";
import TitleEditor from "~/src/components/TitleEditor.vue";
import DocumentContent from "../../components/DocumentContent.vue";
import SpaceLayout from "../../layouts/SpaceLayout.astro";
import { requireSpaceViewer, resolveSpacePage } from "../../utils/spacePage.ts";

const result = await resolveSpacePage(Astro);
if (result.response) {
  return result.response;
}
const { space } = result;

// Check ACL permissions - user must be a member of the space
const accessDenied = await requireSpaceViewer(Astro, space);
if (accessDenied) {
  return accessDenied;
}

const type = Astro.url.searchParams.get("type") || "document";
const category = Astro.url.searchParams.get("category") || undefined;
const title = type === "canvas" ? "Untitled Canvas" : "Untitled Document";
---

<SpaceLayout title={`${title} - ${space.name} - Wiki`}>
    <!-- Inset content past the fixed sidebar — except canvas docs, which render
         full-bleed behind the nav and inset only their (absolute) header below. -->
    <div class={twMerge('flex-1 min-h-0', type !== 'canvas' && 'lg:ml-(--sidebar-width)')}>
    <div
      class={twMerge(
        "space-y-6 mx-auto h-full flex flex-col relative w-full",
        (type !== 'document' && type !== 'workflow') ? 'max-w-full' : 'max-w-(--document-width)'
      )}
     >
      <!-- Document Header -->
      <div class={twMerge(
        type === 'canvas' ? 'absolute top-xs right-0 left-0 lg:left-(--sidebar-width) z-10' : 'pt-s mb-xl'
      )}>
        <div class="flex gap-6 lg:gap-4 justify-between flex-col-reverse lg:flex-row print:px-0 px-xs lg:px-xl mt-xs">
          <div>
            <div class="flex items-start justify-between">
              <TitleEditor client:load initialEditMode={true} title={title} documentId={undefined} />
            </div>
          </div>

          <DocumentActions documentId={undefined} title={title} readonly={false} client:load />
        </div>

        <div class="print:px-0 px-xs lg:px-xl mt-xs">
          <DocumentProperties client:load documentId={undefined} documentType={type} initialProperties={category ? { category } : {}} />
        </div>
      </div>

      <!-- Main Content -->
      <div
        class={twMerge(
          'max-w-none text-neutral-700 h-full',
          type !== 'canvas' && "print:px-0 px-xs lg:px-xl"
        )}
      >
        <DocumentContent
			client:load
			spaceId={space.id}
			documentType={type}
			initialEditMode={true}
		/>

	    <div class="h-full">
      		{type === "canvas" ? (
         			<Canvas
            client:only="vue"
                spaceId={space.id}
         			/>
      		) : null}
		</div>
      </div>
    </div>
    </div>
</SpaceLayout>
