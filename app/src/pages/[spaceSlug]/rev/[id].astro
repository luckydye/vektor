---
import { eq } from "drizzle-orm";
import { getSpaceDb } from "../../../db/db.ts";
import { document, revision } from "../../../db/schema.ts";
import { requireSpaceViewer, resolveSpacePage } from "../../../utils/spacePage.ts";

const result = await resolveSpacePage(Astro);
if (result.response) {
  return result.response;
}
const { space } = result;

// Check ACL permissions - user must be a member of the space
const accessDenied = await requireSpaceViewer(Astro, space);
if (accessDenied) {
  return accessDenied;
}

const { spaceSlug, id } = Astro.params;

if (!id) {
  return new Response(null, {
    status: 404,
    statusText: "Not found",
  });
}

const db = await getSpaceDb(space.id);

// Find the revision by its ID
const rev = await db
  .select({
    rev: revision.rev,
    documentId: revision.documentId,
  })
  .from(revision)
  .where(eq(revision.id, id))
  .get();

if (!rev) {
  return new Response(null, {
    status: 404,
    statusText: "Revision not found",
  });
}

// Get the document slug
const doc = await db
  .select({ slug: document.slug })
  .from(document)
  .where(eq(document.id, rev.documentId))
  .get();

if (!doc) {
  return new Response(null, {
    status: 404,
    statusText: "Document not found",
  });
}

return Astro.redirect(`/${spaceSlug}/doc/${doc.slug}?revision=${rev.rev}`);
---
