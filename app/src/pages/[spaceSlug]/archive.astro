---
import { verifySpaceRole } from "../../db/api.ts";
import { resolveSpacePage } from "../../utils/spacePage.ts";

const result = await resolveSpacePage(Astro);
if (result.response) {
  return result.response;
}
const { space } = result;

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect("/login");
}

await verifySpaceRole(space.id, user.id, "editor");
---

<SpaceLayout title={`Archive - ${space.name} - Wiki`}>
  <div class="mx-auto pt-m pb-20 lg:pb-8 overflow-hidden h-full print:px-0 px-xs lg:px-xl w-full">
    <h1 class="text-3xl font-bold mb-6">Archived Documents</h1>
    <ArchivedDocuments client:load spaceId={space.id} spaceSlug={space.slug} />
  </div>
</SpaceLayout>
