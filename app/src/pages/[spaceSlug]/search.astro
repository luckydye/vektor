---
import SearchComponent from "../../components/Search.vue";
import { verifySpaceAccess } from "../../db/api.ts";
import SpaceLayout from "../../layouts/SpaceLayout.astro";
import { t } from "../../utils/lang.ts";
import { resolveSpacePage } from "../../utils/spacePage.ts";

const lang = Astro.preferredLocale || "en";

const result = await resolveSpacePage(Astro);
if (result.response) {
  return result.response;
}
const { space } = result;

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect("/login");
}

await verifySpaceAccess(space.id, user.id);
---

<SpaceLayout title={`Search - ${space.name} - Wiki`}>
  <div data-inset class="pt-m pb-20 lg:pb-8 overflow-hidden h-full print:px-0 px-xs lg:px-xl lg:ml-(--inset-left) lg:mr-(--inset-right)">
    <div class="mb-8">
        <h1 class="text-size-display font-bold text-neutral-900">{t("Find Documents", lang)}</h1>
        <p class="mt-2 text-size-medium text-neutral-600">
            {t("Search across all documents you have access to in this space with semantic ranking", lang)}
        </p>
    </div>
      
    <SearchComponent client:load spaceId={space.id} spaceSlug={space.slug} />
  </div>
</SpaceLayout>
