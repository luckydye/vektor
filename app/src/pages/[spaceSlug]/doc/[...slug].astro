---
import { twMerge } from "tailwind-merge";
import Breadcrumbs from "~/src/components/Breadcrumbs.vue";
import AIChatPanel from "../../../components/AIChatPanel.vue";
import DocumentActions from "../../../components/DocumentActions.vue";
import DocumentContent from "../../../components/DocumentContent.vue";
import DocumentProperties from "../../../components/DocumentProperties.vue";
import RestoreButton from "../../../components/RestoreButton.vue";
import RevisionsSidebar from "../../../components/RevisionsSidebar.vue";
import RevisionView from "../../../components/RevisionView.vue";
import TitleEditor from "../../../components/TitleEditor.vue";
import { getUserGroups, hasPermission, ResourceType } from "../../../db/acl.ts";
import { getCategoryBySlug } from "../../../db/categories.ts";
import {
  getDocument,
  getDocumentBreadcrumbs,
  getDocumentBySlug,
} from "../../../db/documents.ts";
import { getPublishedContent } from "../../../db/revisions.ts";
import { getSpaceBySlug } from "../../../db/spaces.ts";
import { withTransformParams } from "../../../files/transforms.ts";
import SpaceLayout from "../../../layouts/SpaceLayout.astro";
import { readOnlyDocumentTypes } from "../../../utils/documentTypes.ts";

const { spaceSlug, slug } = Astro.params;

function redirectPreservingSearch(pathname: string) {
  return Astro.redirect(`${pathname}${Astro.url.search}`);
}

if (!spaceSlug || !slug) {
  return Astro.redirect("/");
}

const space = await getSpaceBySlug(spaceSlug);

if (!space) {
  return new Response(null, {
    status: 404,
    statusText: "Space not found",
  });
}

if (spaceSlug !== space.slug) {
  return redirectPreservingSearch(`/${space.slug}/doc/${slug}`);
}

const document = await getDocumentBySlug(space.id, slug);

if (!document) {
  const doc = await getDocument(space.id, slug);
  if (doc) {
    return redirectPreservingSearch(`/${space.slug}/doc/${doc.slug}`);
  }

  return new Response(null, {
    status: 404,
    statusText: "Document not found",
  });
}

// Check ACL permissions - allow unauthenticated users for public documents
const userId = Astro.locals.user?.id || null;
const userGroups = userId ? await getUserGroups(userId) : ["public"];

const hasAccess = await hasPermission(
  space.id,
  ResourceType.DOCUMENT,
  document.id,
  userId || "",
  "viewer",
  userGroups,
);

if (!hasAccess) {
  // If not authenticated and no public access, redirect to login
  if (!Astro.locals.session) {
    return Astro.redirect("/login");
  }

  return new Response(null, {
    status: 403,
    statusText: "Forbidden",
  });
}

const title = document.properties.title || "Untitled Document";
const documentType = document.type ?? "document";
const isCanvas = documentType === "canvas";
const isApp = documentType === "app";
const isCsv = documentType === "csv";
const isWorkflow = documentType === "workflow";
const isPaddedDocument = !isCanvas && !isApp && !isCsv && !isWorkflow;

// Optional header image (stored as a document property; empty string = none)
// Request a width-capped webp transform so the browser doesn't download a
// multi-megapixel original for a 240px-tall banner strip.
const headerImage = document.properties.headerImage
  ? withTransformParams(document.properties.headerImage, {
      w: 1600,
      format: "webp",
      q: 85,
    })
  : null;
const showHeaderImage = !!headerImage && !isCanvas && !isApp && !isWorkflow;

// Archived documents should be treated as readonly
const isReadonly =
  document.readonly ||
  document.archived ||
  isCanvas ||
  isApp ||
  isWorkflow ||
  readOnlyDocumentTypes.includes(documentType);

let htmlContent = document.content;
if (!isCanvas && document.publishedRev !== null) {
  const publishedContent = await getPublishedContent(space.id, document.id);
  if (publishedContent) {
    htmlContent = publishedContent;
  }
}

// Get breadcrumb data
const breadcrumbs = await getDocumentBreadcrumbs(space.id, document.id);
// Remove the current document from breadcrumbs (it's shown separately)
const parentBreadcrumbs = breadcrumbs.slice(0, -1);

// Get category if it exists
let category = null;
const categorySlug = document.properties.category;
if (categorySlug) {
  category = await getCategoryBySlug(space.id, categorySlug);
}

const defaultLayout = documentType === "document" ? "document" : "full";
const effectiveLayout = document.properties.layout || defaultLayout;

const pageInsetClass = twMerge(
  "min-h-0 flex-1",
  !isCanvas && "lg:mr-(--inset-right) lg:ml-(--inset-left)",
);
const documentShellClass = twMerge(
  "relative mx-auto flex h-full w-full flex-col space-y-6",
  isCsv || effectiveLayout === "full" ? "max-w-full" : "max-w-(--document-width)",
);
const documentHeaderClass = twMerge(
  isApp
    ? "hidden"
    : isCanvas
      ? "pointer-events-none absolute top-xs right-0 left-0 z-20 lg:right-(--inset-right) lg:left-(--inset-left)"
      : "mb-xl pt-xs",
);
const headerRowClass = twMerge(
  "flex min-h-7 items-center justify-between px-xs lg:px-xl print:px-0",
  isCanvas && "pointer-events-auto",
);
const titleRowClass = twMerge(
  "mt-xs flex flex-row justify-between gap-6 px-xs lg:gap-4 lg:px-xl print:px-0",
  isCanvas && "pointer-events-auto",
);
const propertiesRowClass = twMerge(
  "mt-xs px-xs lg:px-xl print:px-0",
  isCanvas && "pointer-events-auto",
);
const contentClass = twMerge(
  "max-w-none overflow-auto text-neutral-700",
  isCsv ? "flex min-h-0 flex-1 flex-col overflow-hidden" : "h-full",
  isPaddedDocument && "px-xs lg:px-xl print:px-0",
);

const now = new Date();

let updatedAtStr = "just now";

const diffMs = now.getTime() - document.updatedAt?.getTime();
const diffMins = Math.floor(diffMs / 60000);
const diffHours = Math.floor(diffMs / 3600000);
const diffDays = Math.floor(diffMs / 86400000);

if (diffMins >= 1 && diffMins < 60) {
  updatedAtStr = `${diffMins} minute${diffMins !== 1 ? "s" : ""} ago`;
} else if (diffHours >= 1 && diffHours < 24) {
  updatedAtStr = `${diffHours} hour${diffHours !== 1 ? "s" : ""} ago`;
} else if (diffDays >= 1) {
  updatedAtStr = `${diffDays} day${diffDays !== 1 ? "s" : ""} ago`;
}
---

<SpaceLayout
  title={`${title} - ${space.name} - Wiki`}
  meta={{
    title,
    description: document.properties.description || "",
  }}
>
  <!-- Inset content past the fixed sidebar — except canvas docs, which render
       full-bleed behind the nav and inset only their absolute header below. -->
  <div data-inset class={pageInsetClass}>
    <div
      data-type={documentType}
      data-updated-at={document.updatedAt}
      data-created-at={document.createdAt}
      data-layout={effectiveLayout}
      class={documentShellClass}
    >
      <!-- Archived Document Disclaimer -->
      {document.archived && (
        <div class="bg-yellow-50 border-l-4 border-yellow-400 p-4 mx-4 lg:mx-10">
          <div class="flex items-start justify-between gap-3">
            <div class="space-y-2">
              <div class="text-yellow-600 font-semibold text-size-medium">
                ⚠️ This document is archived
              </div>
              <p class="text-yellow-700 text-size-medium">
                This document has been archived and is no longer actively maintained. You can view it here, but it may be out of date.
              </p>
            </div>
            <RestoreButton client:load documentId={document.id} />
          </div>
        </div>
      )}

      <!-- Header Image -->
      {showHeaderImage && (
        <div class="print:px-0 px-xs lg:px-xl mt-4">
          <img
            src={headerImage}
            alt=""
            class="w-full h-[240px] object-cover rounded-lg"
          />
        </div>
      )}

      <!-- Document Header -->
      <div data-inset class={documentHeaderClass}>
        <div class={headerRowClass}>
          <div>
            {isWorkflow ? (
              <div id="workflow-breadcrumb-slot" />
            ) : (
              <Breadcrumbs
                spaceSlug={spaceSlug}
                category={category}
                parents={parentBreadcrumbs}
                currentTitle={title}
              />
            )}
          </div>

          {document.updatedAt ? (
            <div class="flex flex-wrap items-center gap-2 text-size-medium text-neutral-500">
              {updatedAtStr && <span>Updated {updatedAtStr}</span>}
            </div>
          ) : null}
        </div>

        <div class={titleRowClass}>
          <div class="flex items-start justify-between">
            <TitleEditor
              client:load
              initialEditMode={false}
              title={title}
              documentId={document.id}
            />
          </div>

          <DocumentActions
            client:only
            documentId={document.id}
            title={title}
            readonly={isReadonly}
            documentType={documentType}
            headerImage={headerImage ?? undefined}
          />
        </div>

        <div class={propertiesRowClass}>
          <DocumentProperties
            client:load
            documentId={document.id}
            documentType={documentType}
            initialProperties={{ ...document.properties, parentId: document.parentId }}
            initialCategory={category}
          />
        </div>
      </div>

      <!-- Main Content -->
      <div class={contentClass}>
        <RevisionView
          client:only
          documentId={document.id}
          documentType={documentType}
          spaceId={space.id}
        />
        <DocumentContent
          client:load
          spaceId={space.id}
          documentId={document.id}
          initialHtml={htmlContent}
          documentType={documentType}
          readonly={isReadonly}
        />
      </div>
    </div>
  </div>

  <div slot="outer">
    <RevisionsSidebar client:only documentId={document.id} />
    <AIChatPanel client:only documentId={document.id} />
  </div>
</SpaceLayout>
