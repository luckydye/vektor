---
import FirstSpacePrompt from "#components/FirstSpacePrompt.vue";
import { config } from "#config";
import { getUserGroups, hasPermission, ResourceType } from "#db/acl.ts";
import { getSpaceBySlug, listUserSpaces } from "#db/spaces.ts";
import BaseLayout from "#layouts/BaseLayout.astro";

if (!Astro.locals.session) {
  return Astro.redirect("/login");
}

const appConfig = config();
const userId = Astro.locals.user?.id;

const defaultSpace = appConfig.DEFAULT_SPACE
  ? await getSpaceBySlug(appConfig.DEFAULT_SPACE)
  : null;

if (defaultSpace) {
  const userGroups = await getUserGroups(userId);
  const canAccess = await hasPermission(
    defaultSpace.id,
    ResourceType.SPACE,
    defaultSpace.id,
    userId,
    "viewer",
    userGroups,
  );
  if (canAccess) {
    return Astro.redirect(`/${defaultSpace.slug}`);
  }
}

const userSpaces = await listUserSpaces(userId);

if (userSpaces.length !== 0) {
  const lastVisitedSlug = Astro.cookies.get("lastVisitedSpace")?.value;
  if (lastVisitedSlug) {
    const lastVisited = userSpaces.find((s) => s.slug === lastVisitedSlug);
    if (lastVisited) {
      return Astro.redirect(`/${lastVisited.slug}`);
    }
  }
  return Astro.redirect(`/${userSpaces[0].slug}`);
}
---

<BaseLayout>
  <!-- First Space Onboarding Prompt -->
  <FirstSpacePrompt client:only="vue" />
</BaseLayout>
