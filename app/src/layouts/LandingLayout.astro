---
import "../styles/index.css";

export interface Props {
  title?: string;
}

const { title = "Vektor" } = Astro.props;
const publicEnv = Astro.locals.publicEnv;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/favicon_light.png" media="(prefers-color-scheme: dark)" />
    <link rel="icon" type="image/png" href="/favicon_dark.png" media="(prefers-color-scheme: light)" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <script type="application/json" id="env" set:html={JSON.stringify(publicEnv)}></script>
  </head>
  <body class="font-sans bg-background">
    <slot />
  </body>
</html>
