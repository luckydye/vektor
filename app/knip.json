{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "entry": [
    "vektor.ts",
    "build.ts",
    "src/server.ts",
    "src/app.ts",
    "src/middleware.ts",
    "src/pages/**/*.astro",
    "src/noAuth.ts",
    "public/sw.js",
    "test/**/*.spec.ts",
    "src/**/*.test.ts"
  ],
  "project": ["src/**", "test/**", "*.ts", "public/sw.js"],
  "ignore": ["dist/**", "generated/**", "examples/**", "data/**"],
  "ignoreExportsUsedInFile": true,
  "exclude": ["types", "enumMembers"]
}
