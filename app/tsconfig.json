{
  "extends": "astro/tsconfigs/strict",
  "include": [
    ".astro/types.d.ts",
    "**/*"
  ],
  "exclude": [
    "dist",
    "test",
    "generated",
    "generated/**",
    "src/canvas/viewport/vector-tile.ts"
  ],
  "compilerOptions": {
    "jsx": "preserve",
    "jsxImportSource": "vue",
    "paths": {
      "~/*": ["./*"]
    }
  }
}
